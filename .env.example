# Database Configuration
# For local PostgreSQL: postgresql://user:password@localhost:5432/packeasy
# For Neon/Supabase/Railway: use your provided connection string
# Example: postgresql://postgres:mypassword@localhost:5432/packeasy
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/packeasy

# API Server Configuration
PORT=3000
NODE_ENV=development

# Mobile App Configuration  
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_DOMAIN=localhost
EXPO_PUBLIC_REPL_ID=local
